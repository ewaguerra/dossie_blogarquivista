{
  "rewrites": [
    { "source": "/app/vendor/:path*", "destination": "/vendor/app/vendor/:path*" },
    { "source": "/app/:path*", "destination": "/vendor/app/:path*" },
    { "source": "/pages/centro/assets/:path*", "destination": "/landing/assets/:path*" }
  ],
  "redirects": [
    { "source": "/", "destination": "/arquivo-morto/", "permanent": false }
  ],
  "headers": [
    {
      "source": "/vendor/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
